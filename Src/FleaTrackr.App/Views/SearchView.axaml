<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FleaTrackr.App.ViewModels"
             xmlns:controls="using:FleaTrackr.App.Controls"
             xmlns:conv="using:FleaTrackr.App.Converters"
             x:Class="FleaTrackr.App.Views.SearchView"
             x:DataType="vm:SearchViewModel">

    <Grid ColumnDefinitions="380,*" Margin="4">

        <!-- Left: search box + results list -->
        <DockPanel Grid.Column="0" Margin="4">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBox Grid.Column="0" Text="{Binding Query}"
                         PlaceholderText="Search items (e.g. GPU, LEDX, bitcoin)..."
                         ToolTip.Tip="Type part of an item name. Results update as you type and show live flea prices for the selected economy." />
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="80" Margin="8,0,0,0"
                             VerticalAlignment="Center" IsVisible="{Binding IsBusy}" />
            </Grid>

            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Sort" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                          ToolTip.Tip="Reorder the results list. 'Relevance' keeps the API's match order.">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchSortOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <TextBlock DockPanel.Dock="Bottom" Margin="2,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Text="{Binding StatusMessage}" />

            <TextBlock DockPanel.Dock="Bottom" Margin="2,6,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding IsEmptyResult}"
                       Text="No items matched that search." />

            <ListBox ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     ToolTip.Tip="Each row shows the flea sell price and the 48h change (green up, red down). Select an item for full price detail.">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ItemRowViewModel">
                        <Grid ColumnDefinitions="*,Auto,64" Margin="0,2">
                            <StackPanel Grid.Column="0" Spacing="1">
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ShortName}" FontSize="11"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="6,0"
                                       Text="{Binding FleaSellText}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       HorizontalAlignment="Right" Text="{Binding ChangeText}"
                                       Foreground="{Binding ChangeValue, Converter={x:Static conv:SignToBrushConverter.Instance}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: detail pane for the selected item -->
        <Border Grid.Column="1" Margin="4" Padding="16" BorderThickness="1" CornerRadius="6"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">

            <Panel>
                <!-- Placeholder shown until an item is selected. -->
                <TextBlock IsVisible="{Binding SelectedResult, Converter={x:Static ObjectConverters.IsNull}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Text="Select an item to see its prices." />

                <!-- Detail binds off SearchViewModel via SelectedResult.* so the sparkline, icon,
                     and wiki command (which live on the parent VM) need no parent traversal. -->
                <ScrollViewer IsVisible="{Binding SelectedResult, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="14">

                        <!-- Header: icon + names -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="64" Height="64" Background="#22808080" CornerRadius="4">
                                <Image Source="{Binding SelectedIcon}" Stretch="Uniform" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding SelectedResult.Name}" FontSize="18" FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedResult.ShortName}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Flea price history -->
                        <StackPanel Spacing="4"
                                    ToolTip.Tip="Flea sell price over the selected window. The dot marks the most recent point; High/Low/Last summarise the range.">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Flea price history" FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                <ListBox Grid.Column="1" Classes="range"
                                         ItemsSource="{Binding HistoryRanges}"
                                         SelectedItem="{Binding SelectedHistoryRange}"
                                         ToolTip.Tip="Choose how far back to chart: 7, 30, or 90 days.">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="2" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HistoryRange">
                                            <TextBlock Text="{Binding Label}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <controls:Sparkline Height="72" Points="{Binding SparklinePoints}"
                                                Stroke="#3B82F6" Fill="#223B82F6" />
                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="High" FontSize="10" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    <TextBlock Text="{Binding ChartHighText}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Low" FontSize="10" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    <TextBlock Text="{Binding ChartLowText}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Last" FontSize="10" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    <TextBlock Text="{Binding ChartLastText}" FontSize="12" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Price breakdown -->
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="18" RowSpacing="7">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Flea sell" Classes="label"
                                       ToolTip.Tip="What you would receive selling this on the flea market right now (before the sales fee)." />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedResult.FleaSellText}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Flea buy" Classes="label"
                                       ToolTip.Tip="The cheapest current asking price to buy this on the flea market." />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedResult.FleaBuyText}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="24h average" Classes="label"
                                       ToolTip.Tip="Average flea price over the last 24 hours." />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedResult.Avg24hText}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="24h low / high" Classes="label"
                                       ToolTip.Tip="Lowest and highest flea price seen in the last 24 hours." />
                            <TextBlock Grid.Row="3" Grid.Column="1">
                                <Run Text="{Binding SelectedResult.Low24hText}" /><Run Text="  /  " /><Run Text="{Binding SelectedResult.High24hText}" />
                            </TextBlock>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="48h change" Classes="label"
                                       ToolTip.Tip="Percent change in flea price over the last 48 hours. Green is up, red is down." />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedResult.ChangeText}"
                                       Foreground="{Binding SelectedResult.ChangeValue, Converter={x:Static conv:SignToBrushConverter.Instance}}" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Best trader" Classes="label"
                                       ToolTip.Tip="The trader that pays the most for this item, and how much (in roubles)." />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedResult.BestTraderText}" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Base price" Classes="label"
                                       ToolTip.Tip="The item's internal handbook value. Used to estimate the flea sales fee, not a price you can trade at." />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedResult.BasePriceText}" />
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Offers" Classes="label"
                                       ToolTip.Tip="How many active flea listings there were at the last update - a rough liquidity gauge." />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedResult.OfferCountText}" />
                        </Grid>

                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding FleaLockText}" FontSize="12" FontWeight="SemiBold"
                                       IsVisible="{Binding FleaLockText, Converter={x:Static ObjectConverters.IsNotNull}}"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                            <TextBlock Text="{Binding SelectedResult.MinFleaLevelText}" FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding SelectedResult.UpdatedText}" FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="{Binding AddToWatchlistText}"
                                    Command="{Binding AddToWatchlistCommand}"
                                    IsEnabled="{Binding CanAddToWatchlist}"
                                    ToolTip.Tip="Track this item on the Watchlist tab, where it refreshes automatically and can raise price alerts." />
                            <Button Content="Open wiki page" Command="{Binding OpenWikiCommand}"
                                    ToolTip.Tip="Open this item's page on the Escape from Tarkov wiki in your browser." />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
        <!-- Compact segmented look for the chart range selector. -->
        <Style Selector="ListBox.range">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.range ListBoxItem">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </UserControl.Styles>
</UserControl>
