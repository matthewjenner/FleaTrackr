<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FleaTrackr.App.ViewModels"
             xmlns:conv="using:FleaTrackr.App.Converters"
             x:Class="FleaTrackr.App.Views.WatchlistView"
             x:DataType="vm:WatchlistViewModel">

    <Grid ColumnDefinitions="*,260" Margin="4">

        <!-- Watched items -->
        <Panel Grid.Column="0" Margin="4">
            <TextBlock IsVisible="{Binding IsEmpty}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Text="Your watchlist is empty. Find an item on the Search tab and click 'Add to watchlist' to track its price here." />

            <ScrollViewer IsVisible="{Binding !IsEmpty}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WatchlistItemViewModel">
                            <Border Margin="0,0,0,8" Padding="12" CornerRadius="6" BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    Background="{Binding IsAlerting, Converter={x:Static conv:AlertHighlightConverter.Instance}}">
                                <StackPanel Spacing="8">

                                    <!-- Top line: icon, name, live price + trend -->
                                    <Grid ColumnDefinitions="40,*,Auto">
                                        <Image Grid.Column="0" Width="36" Height="36" Source="{Binding Icon}"
                                               Stretch="Uniform" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding LastRefreshedText}" FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding PriceText}" FontSize="16" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right" />
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right"
                                                        TextElement.Foreground="{Binding ChangeValue, Converter={x:Static conv:SignToBrushConverter.Instance}}">
                                                <TextBlock Text="{Binding TrendArrow}" />
                                                <TextBlock Text="{Binding ChangeText}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Controls: cadence + actions -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" >
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock Text="Refresh" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                            <ComboBox ItemsSource="{Binding RefreshOptions}"
                                                      SelectedItem="{Binding SelectedRefresh}" MinWidth="120">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:RefreshOption">
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Refresh now" Margin="8,0,0,0"
                                                Command="{Binding RefreshNowCommand}" />
                                        <Button Grid.Column="3" Content="Remove" Margin="6,0,0,0"
                                                Command="{Binding RemoveCommand}" />
                                    </Grid>

                                    <!-- Alerts editor -->
                                    <Expander Header="{Binding AlertSummary, StringFormat='Alerts: {0}'}">
                                        <StackPanel Spacing="8" Margin="0,4,0,0">
                                            <Grid ColumnDefinitions="Auto,140" RowDefinitions="Auto,Auto,Auto"
                                                  ColumnSpacing="10" RowSpacing="6">
                                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                                           Text="Alert when price drops below (RUB)" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PriceBelow}" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                                           Text="Alert when price rises above (RUB)" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PriceAbove}" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                                           Text="Alert on 48h move exceeding (%)" />
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PercentMove}" />
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Apply alerts" Command="{Binding ApplyAlertsCommand}" />
                                                <Button Content="Clear" Command="{Binding ClearAlertsCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>

        <!-- Alert feed -->
        <DockPanel Grid.Column="1" Margin="4">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Alerts" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearAlertFeedCommand}" />
            </Grid>
            <Border BorderThickness="1" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding RecentAlerts}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,3" FontSize="12" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
