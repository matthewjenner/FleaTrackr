<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FleaTrackr.App.ViewModels"
        xmlns:views="using:FleaTrackr.App.Views"
        x:Class="FleaTrackr.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="{Binding Title}"
        Width="1040" Height="680"
        MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Update banner: docked at the very top, shown only when a newer release exists. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding IsUpdateBannerVisible}"
                Background="#1F6FEB" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Text="{Binding UpdateBannerText}" />
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Content="Install"
                        IsEnabled="{Binding CanInstallUpdate}"
                        Command="{Binding InstallUpdateCommand}"
                        ToolTip.Tip="Download the new version and restart into it. Disabled when running from source (dotnet run)." />
                <Button Grid.Column="2" Margin="8,0,0,0"
                        Content="Skip this version"
                        Command="{Binding SkipUpdateCommand}"
                        ToolTip.Tip="Hide this update until an even newer version is released." />
                <Button Grid.Column="3" Margin="8,0,0,0"
                        Content="Later"
                        Command="{Binding DismissUpdateCommand}"
                        ToolTip.Tip="Dismiss the banner for now; it returns on the next update check." />
            </Grid>
        </Border>

        <!-- App header: title + the PVP/PVE economy toggle that drives every price query. -->
        <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold" Text="FleaTrackr" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center"
                            ToolTip.Tip="EFT runs two separate economies with different prices. Switch here and every tab re-queries prices for that mode.">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Text="Economy:" />
                    <RadioButton GroupName="GameMode" Content="PVP" IsChecked="{Binding IsPvp}"
                                 ToolTip.Tip="Standard online PVP raids." />
                    <RadioButton GroupName="GameMode" Content="PVE" IsChecked="{Binding IsPve}"
                                 ToolTip.Tip="PVE (co-op / offline) economy. Prices differ from PVP." />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab content. Each TabItem gets its real View/ViewModel in the phase that builds it. -->
        <TabControl Margin="8" SelectedIndex="{Binding ActiveTabIndex}">
            <TabItem Header="Search">
                <views:SearchView DataContext="{Binding Search}" />
            </TabItem>
            <TabItem Header="Watchlist">
                <views:WatchlistView DataContext="{Binding Watchlist}" />
            </TabItem>
            <TabItem Header="Barters &amp; Crafts">
                <views:BartersCraftsView DataContext="{Binding BartersCrafts}" />
            </TabItem>
            <TabItem Header="Flip Finder">
                <views:FlipFinderView DataContext="{Binding FlipFinder}" />
            </TabItem>
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
