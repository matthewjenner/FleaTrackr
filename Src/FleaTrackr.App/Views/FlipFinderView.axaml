<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FleaTrackr.App.ViewModels"
             xmlns:conv="using:FleaTrackr.App.Converters"
             x:Class="FleaTrackr.App.Views.FlipFinderView"
             x:DataType="vm:FlipFinderViewModel">

    <DockPanel Margin="8">

        <!-- Controls -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8"
                    VerticalAlignment="Center">
            <TextBlock Text="Min profit (RUB)" VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       ToolTip.Tip="Only show flips worth at least this much net profit. Defaults from Settings; change it here for this scan." />
            <TextBox Text="{Binding MinProfit}" Width="100"
                     ToolTip.Tip="Roubles. Raise it to hide small flips." />
            <Button Content="Scan market" Command="{Binding ScanCommand}"
                    ToolTip.Tip="Scan a slice of the market (up to 2000 items) for trader/flea arbitrage. Items above your character level are skipped. Uses several API requests." />
            <Button Content="Cancel" Command="{Binding ScanCancelCommand}"
                    IsVisible="{Binding IsScanning}"
                    ToolTip.Tip="Stop the scan and keep whatever was found so far." />
            <ProgressBar IsIndeterminate="True" Width="90" IsVisible="{Binding IsScanning}"
                         VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" Margin="2,0,0,8"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

        <!-- Column headers -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,150,190,190,120,90" Margin="12,0,12,4">
            <TextBlock Grid.Column="0" Text="Item" Classes="header" />
            <TextBlock Grid.Column="1" Text="Direction" Classes="header"
                       ToolTip.Tip="'Trader -&gt; Flea' means buy from a trader and resell on the flea market. 'Flea -&gt; Trader' means buy on the flea market and sell to a trader." />
            <TextBlock Grid.Column="2" Text="Buy" Classes="header"
                       ToolTip.Tip="Where you buy, and the price you pay." />
            <TextBlock Grid.Column="3" Text="Sell" Classes="header"
                       ToolTip.Tip="Where you sell, and the price. Trader-to-flea rows show the estimated flea fee that has already been subtracted from profit." />
            <TextBlock Grid.Column="4" Text="Profit" Classes="header"
                       ToolTip.Tip="Net profit per item: sell price minus the flea fee (if any) minus the buy price." />
            <TextBlock Grid.Column="5" Text="ROI" Classes="header"
                       ToolTip.Tip="Return on investment: profit as a percent of the buy price." />
        </Grid>

        <!-- Results -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FlipRowViewModel">
                        <Border Padding="12,6" BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                            <Grid ColumnDefinitions="*,150,190,190,120,90">
                                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ShortName}" FontSize="11"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding DirectionText}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding BuyText}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SellText}" />
                                    <TextBlock Text="{Binding FeeText}" FontSize="10" IsVisible="{Binding IsFleaSale}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="4" Text="{Binding ProfitText}" VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding ProfitValue, Converter={x:Static conv:SignToBrushConverter.Instance}}" />
                                <TextBlock Grid.Column="5" Text="{Binding RoiText}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

    <UserControl.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
    </UserControl.Styles>
</UserControl>
