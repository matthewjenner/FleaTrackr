<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FleaTrackr.App.ViewModels"
             xmlns:conv="using:FleaTrackr.App.Converters"
             x:Class="FleaTrackr.App.Views.BartersCraftsView"
             x:DataType="vm:BartersCraftsViewModel">

    <UserControl.Resources>
        <!-- Shared row template for both barters and crafts. -->
        <DataTemplate x:Key="TradeTemplate" x:DataType="vm:TradeRowViewModel">
            <Border Margin="0,0,0,8" Padding="12" CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Source}" FontWeight="SemiBold" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding IsCraft}">
                            <TextBlock Text="{Binding DurationText}" FontSize="12"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="1">
                        <TextBlock FontSize="12"
                                   ToolTip.Tip="What you hand over for this trade, valued at the cheapest way to acquire each item (flea or trader).">
                            <Run Text="Give: " Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" /><Run Text="{Binding RequirementsText}" />
                        </TextBlock>
                        <TextBlock FontSize="12"
                                   ToolTip.Tip="What you receive, valued at its flea sell price (or best trader if it is not on the flea market).">
                            <Run Text="Get: " Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" /><Run Text="{Binding RewardText}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Cost / value / profit / ROI -->
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <StackPanel ToolTip.Tip="Total cost to acquire the input items (cheapest of flea or trader).">
                            <TextBlock Text="Cost" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding InputCostText}" />
                        </StackPanel>
                        <StackPanel ToolTip.Tip="Value of the reward, net of the estimated flea sales fee when sold on the flea market.">
                            <TextBlock Text="Value" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding OutputValueText}" />
                        </StackPanel>
                        <StackPanel ToolTip.Tip="Value minus cost. Shown as '-' when a required or reward item has no known price. Green is a gain, red a loss.">
                            <TextBlock Text="Profit" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding ProfitText}" FontWeight="SemiBold"
                                       Foreground="{Binding ProfitValue, Converter={x:Static conv:SignToBrushConverter.Instance}}" />
                        </StackPanel>
                        <StackPanel ToolTip.Tip="Return on investment: profit as a percent of the input cost.">
                            <TextBlock Text="ROI" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding RoiText}" />
                        </StackPanel>
                        <StackPanel IsVisible="{Binding IsCraft}"
                                    ToolTip.Tip="Profit divided by the craft's duration - useful for comparing crafts that take different times.">
                            <TextBlock Text="Profit/hr" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding ProfitPerHourText}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnDefinitions="320,*" Margin="4">

        <!-- Left: item picker -->
        <DockPanel Grid.Column="0" Margin="4">
            <TextBox DockPanel.Dock="Top" Text="{Binding Query}" Margin="0,0,0,6"
                     PlaceholderText="Find an item (e.g. LEDX, GPU)..."
                     ToolTip.Tip="Search for the item you want to produce, then select it to see the barters and crafts that make it." />
            <ListBox ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ItemRowViewModel">
                        <StackPanel Spacing="1" Margin="0,2">
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ShortName}" FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: barters + crafts -->
        <Panel Grid.Column="1" Margin="4">
            <TextBlock IsVisible="{Binding !HasSelection}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Text="Pick an item on the left to see the barters and hideout crafts that produce it, with profit against current flea prices." />

            <ProgressBar IsIndeterminate="True" Width="120" VerticalAlignment="Top"
                         HorizontalAlignment="Center" Margin="0,8" IsVisible="{Binding IsBusy}" />

            <ScrollViewer IsVisible="{Binding HasSelection}">
                <StackPanel Spacing="8">
                    <TextBlock IsVisible="{Binding NoTrades}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Text="This item has no barters or crafts." />

                    <TextBlock Text="Barters" FontSize="15" FontWeight="SemiBold"
                               IsVisible="{Binding HasBarters}" />
                    <ItemsControl ItemsSource="{Binding Barters}" ItemTemplate="{StaticResource TradeTemplate}" />

                    <TextBlock Text="Crafts" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"
                               IsVisible="{Binding HasCrafts}" />
                    <ItemsControl ItemsSource="{Binding Crafts}" ItemTemplate="{StaticResource TradeTemplate}" />
                </StackPanel>
            </ScrollViewer>
        </Panel>
    </Grid>
</UserControl>
