<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FleaTrackr.App.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows the system theme. "Dark" or "Light" force one. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
